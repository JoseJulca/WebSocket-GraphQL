@page
@model BookStoreWebApp.Pages.IndexModel
@{
    ViewData["Title"] = "BookStore GraphQL";
    var apiUrl = Model.ApiUrl;
}

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>BookStore · GraphQL</title>
  <link rel="stylesheet" href="/css/books.css"/>
</head>
<body>

<header class="top-bar">
  <div class="brand">
    <span class="gql-logo">&#x29C2;</span>
    <span>BookStore <em>GraphQL</em></span>
  </div>
  <span id="sub-status" class="sub-badge">⬤ Subscripción activa</span>
</header>

<div class="layout">

  <!-- Panel izquierdo: filtros + agregar -->
  <aside class="panel">

    <section class="card">
      <h3>Consultar libros</h3>
      <div class="field">
        <label>Género</label>
        <select id="filterGenre">
          <option value="">Todos</option>
          <option>Programación</option>
          <option>Arquitectura</option>
          <option>Sistemas</option>
        </select>
      </div>
      <div class="field">
        <label>Solo en stock</label>
        <input type="checkbox" id="filterStock"/>
      </div>
      <button onclick="loadBooks()">Consultar →</button>
    </section>

    <section class="card">
      <h3>Agregar libro</h3>
      <div class="field"><label>Título</label>
        <input id="addTitle" type="text" placeholder="Título"/></div>
      <div class="field"><label>Autor</label>
        <input id="addAuthor" type="text" placeholder="Autor"/></div>
      <div class="field"><label>Género</label>
        <input id="addGenre" type="text" placeholder="Ej. Programación"/></div>
      <div class="field"><label>Precio (S/)</label>
        <input id="addPrice" type="number" step="0.01" placeholder="0.00"/></div>
      <div class="field"><label>Año</label>
        <input id="addYear" type="number" placeholder="2024"/></div>
      <button onclick="addBook()">Agregar libro</button>
    </section>

    <section class="card query-box">
      <h3>Query enviada</h3>
      <pre id="queryDisplay">–</pre>
    </section>

  </aside>

  <!-- Panel derecho: resultados -->
  <main class="results">
    <div class="results-header">
      <h2>Catálogo <span id="bookCount" class="count-badge"></span></h2>
      <p class="hint">Los libros nuevos aparecen aquí en tiempo real vía <strong>Subscription</strong></p>
    </div>
    <div id="bookList" class="book-grid"></div>
    <div id="emptyState" class="empty-state" style="display:none">No se encontraron libros.</div>
  </main>

</div>

<div id="toast" class="toast"></div>

<script>
const API = "@apiUrl";
const WS_API = API.replace("http://", "ws://").replace("https://", "wss://");

/* ─── GraphQL fetch helper ─── */
async function gql(query, variables = {}) {
  document.getElementById("queryDisplay").textContent =
    query.trim().replace(/\s+/g, " ").substring(0, 400);

  const res = await fetch(API, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ query, variables })
  });
  const json = await res.json();
  if (json.errors) throw new Error(json.errors[0].message);
  return json.data;
}

/* ─── Render libros ─── */
function renderBooks(books) {
  const list = document.getElementById("bookList");
  const empty = document.getElementById("emptyState");
  document.getElementById("bookCount").textContent = books.length;

  if (!books.length) {
    list.innerHTML = "";
    empty.style.display = "block";
    return;
  }
  empty.style.display = "none";
  list.innerHTML = books.map(b => `
    <div class="book-card ${b.inStock ? "" : "out-of-stock"}">
      <div class="book-header">
        <span class="genre-tag">${b.genre}</span>
        ${b.inStock
          ? '<span class="stock-tag in">En stock</span>'
          : '<span class="stock-tag out">Agotado</span>'}
      </div>
      <h4>${b.title}</h4>
      <p class="author">${b.author} · ${b.year}</p>
      <div class="book-footer">
        <span class="price">S/ ${b.price.toFixed(2)}</span>
        <button class="btn-delete" onclick="deleteBook(${b.id})">Eliminar</button>
      </div>
    </div>
  `).join("");
}

/* ─── Query: listar libros ─── */
async function loadBooks() {
  const genre = document.getElementById("filterGenre").value;
  const stock = document.getElementById("filterStock").checked;

  let where = "";
  const conditions = [];
  if (genre)  conditions.push(`genre: { eq: "${genre}" }`);
  if (stock)  conditions.push(`inStock: { eq: true }`);
  if (conditions.length) where = `(where: { ${conditions.join(", ")} })`;

  const q = `query { books${where} { id title author genre price year inStock } }`;
  try {
    const data = await gql(q);
    renderBooks(data.books);
  } catch(e) { showToast("Error: " + e.message, "error"); }
}

/* ─── Mutation: agregar libro ─── */
async function addBook() {
    const title  = document.getElementById("addTitle").value.trim();
    const author = document.getElementById("addAuthor").value.trim();
    const genre  = document.getElementById("addGenre").value.trim();
    const price  = parseFloat(document.getElementById("addPrice").value) || 0;
    const year   = parseInt(document.getElementById("addYear").value)    || new Date().getFullYear();

    if (!title || !author) { showToast("Título y autor son obligatorios", "error"); return; }

    const mutation = `
    mutation {
        addBook(input: {
        title:  "${title.replace(/"/g, '\\"')}",
        author: "${author.replace(/"/g, '\\"')}",
        genre:  "${genre.replace(/"/g, '\\"')}",
        price:  ${price},
        year:   ${year}
        }) { id title author genre price year inStock }
    }`;
    try {
    await gql(mutation, {});
    showToast(`"${title}" agregado correctamente`, "ok");
    ["addTitle","addAuthor","addGenre","addPrice","addYear"]
        .forEach(id => document.getElementById(id).value = "");
    loadBooks();
    } catch(e) { showToast("Error: " + e.message, "error"); }
}

/* ─── Mutation: eliminar libro ─── */
async function deleteBook(id) {
  const mutation = `mutation { deleteBook(id: ${id}) { id title } }`;
  try {
    const data = await gql(mutation);
    showToast(`"${data.deleteBook?.title}" eliminado`, "ok");
    loadBooks();
  } catch(e) { showToast("Error: " + e.message, "error"); }
}

/* ─── Subscription via WebSocket ─── */
function startSubscription() {
  const ws = new WebSocket(WS_API, "graphql-transport-ws");

  ws.onopen = () => {
    ws.send(JSON.stringify({ type: "connection_init", payload: {} }));
  };

  ws.onmessage = (e) => {
    const msg = JSON.parse(e.data);
    if (msg.type === "connection_ack") {
      ws.send(JSON.stringify({
        id: "sub1", type: "subscribe",
        payload: { query: `subscription { onBookAdded { id title author } }` }
      }));
      document.getElementById("sub-status").classList.add("active");
    }
    if (msg.type === "next") {
      const book = msg.payload?.data?.onBookAdded;
      if (book) {
        showToast(`📚 Nuevo libro: "${book.title}" — ${book.author}`, "ok");
        loadBooks();
      }
    }
    if (msg.type === "error" || msg.type === "complete") {
      document.getElementById("sub-status").classList.remove("active");
    }
  };

  ws.onclose = () => {
    document.getElementById("sub-status").classList.remove("active");
    setTimeout(startSubscription, 4000);
  };
}

/* ─── Toast ─── */
function showToast(msg, type = "ok") {
  const t = document.getElementById("toast");
  t.textContent = msg;
  t.className = "toast show " + type;
  setTimeout(() => t.className = "toast", 3500);
}

/* ─── Init ─── */
loadBooks();
startSubscription();
</script>
</body>
</html>
